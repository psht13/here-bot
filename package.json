{
  "name": "here-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Telegram group mention bot with inline support for tracked members and custom mention groups.",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "start": "node --enable-source-maps dist/index.js",
    "test": "node --test --import tsx ./src/**/*.test.ts"
  },
  "dependencies": {
    "dotenv": "^16.5.0",
    "grammy": "^1.38.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2"
  }
}
