{
  "name": "here-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Telegram group mention bot with inline support for tracked members and custom mention groups.",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "check": "npm run typecheck",
    "lint": "eslint --max-warnings=0 \"src/**/*.ts\"",
    "format": "prettier --check .",
    "start": "node --enable-source-maps dist/main.js",
    "test": "node --test --import tsx ./src/**/*.test.ts",
    "test:coverage": "node --test --import tsx --experimental-test-coverage --test-coverage-include='src/**/*.ts' --test-coverage-exclude='src/**/*.test.ts' --test-coverage-lines=90 --test-coverage-branches=90 --test-coverage-functions=90 ./src/**/*.test.ts",
    "ci": "npm run typecheck && npm run lint && npm run test:coverage && npm run build"
  },
  "dependencies": {
    "dotenv": "^16.5.0",
    "grammy": "^1.38.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.3.0",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.59.2"
  }
}
